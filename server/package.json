{
  "name": "macros100-server",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "build": "rimraf dist && tsc && copyfiles -u 1 \"src/*.cjs\" dist",
    "dev": "nodemon --watch src/**/*.ts --exec node --loader ts-node/esm src/index.ts"
  },
  "dependencies": {
    "body-parser": "^2.2.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "javascript-lp-solver": "^1.0.3"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.10",
    "copyfiles": "^2.4.1",
    "nodemon": "^3.1.11",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
